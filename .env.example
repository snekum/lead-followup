# Copy to .env for local (non-Docker) runs. Docker Compose sets its own values.
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

DATABASE_URL=postgresql+psycopg2://saarthi:saarthi@localhost:5432/saarthi
REDIS_URL=redis://localhost:6379/0

# mock | meta
WHATSAPP_PROVIDER=mock

# Assistant LLM: gemini (default) | claude | fake
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Only needed if LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Cadence quiet hours (local 24h clock); no outbound sends in [start, end)
QUIET_HOURS_START=21
QUIET_HOURS_END=9
