# Copy to .env for local (non-Docker) runs. Docker Compose sets its own values.
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

DATABASE_URL=postgresql+psycopg2://saarthi:saarthi@localhost:5432/saarthi
REDIS_URL=redis://localhost:6379/0

# mock | meta   (Meta Cloud API provider arrives in M2)
WHATSAPP_PROVIDER=mock

# Cadence quiet hours (local 24h clock); no outbound sends in [start, end)
QUIET_HOURS_START=21
QUIET_HOURS_END=9
